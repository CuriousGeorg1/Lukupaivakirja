PORT=3001
NODE_ENV=development

# Frontend URL (CORS:ia varten)
# Kehityksessä:
FRONTEND_URL=http://localhost:3000
# Tuotannossa Renderissä aseta tämä frontend-palvelun URL:ksi, esim:
# FRONTEND_URL=https://lukupaivakirja-frontend.onrender.com

# Azure SQL Database (tuotanto)
# AZURE_SQL_CONNECTION_STRING=mssql://username:password@server.database.windows.net:1433/lukupaivakirja?encrypt=true

# Tai PostgreSQL (tuotanto)
# POSTGRESQL_CONNECTION_STRING=postgresql://username:password@server.postgres.database.azure.com:5432/lukupaivakirja?ssl=true
